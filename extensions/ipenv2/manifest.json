{
  "manifest_version": 3,
  "name": "iPEN - Otimizador Operacional",
  "version": "1.0",
  "description": "Interface Pro para o sistema iPEN",
  "permissions": ["storage"],

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.sc.gov.br/sap/ipen/*",
        "https://www.sc.gov.br/ipen/*"
      ],
      "js": ["correcoes.js", "sidebar.js", "relatorio15.js", "autoimport.js", "coleta.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}
