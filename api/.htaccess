# SIGEP API - URLs Amigáveis
# Rewrite para endpoints amigáveis

RewriteEngine On

# Base path
RewriteBase /api/

# Evitar acesso direto a arquivos de config
<FilesMatch "^config">
    Require all denied
</FilesMatch>

# Rota: /api/internos → /api/endpoints/internos.php
RewriteRule ^internos$ endpoints/internos.php [L,QSA]

# Rota: /api/internos?ipen=123 → /api/endpoints/internos.php?ipen=123
RewriteRule ^internos$ endpoints/internos.php [L,QSA]

# Rota: /api/usuarios → /api/endpoints/usuarios.php
RewriteRule ^usuarios$ endpoints/usuarios.php [L,QSA]

# Rota genérica: /api/{tabela} → /api/endpoints/{tabela}.php
RewriteRule ^([a-zA-Z0-9_-]+)$ endpoints/$1.php [L,QSA]

# Rota versão v1: /api/v1/{endpoint} → /api/v1/endpoints/{endpoint}.php
RewriteRule ^v1/([a-zA-Z0-9_-]+)$ v1/endpoints/$1.php [L,QSA]

# Headers de segurança
<IfModule mod_headers.c>
    Header set X-Content-Type-Options nosniff
    Header set X-Frame-Options SAMEORIGIN
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
